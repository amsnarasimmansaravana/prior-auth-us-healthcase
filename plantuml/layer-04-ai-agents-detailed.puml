@startuml layer-04-ai-agents-detailed
!theme aws-orange
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam nodesep 180
skinparam ranksep 140
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam defaultFontSize 11

title <size:20><b>Layer 4: AI Agent Fabric - Hybrid Model Architecture</b></size>\n<size:14>11 Specialized Agents | Proprietary + In-House Models | Fallback Strategy | 385,000 executions/day</size>\n<size:12>Cost: $19,760/day (62% reduction via in-house models)</size>\n\n

' ============================================================================
' AI AGENTS
' ============================================================================

package "**AI AGENT FABRIC LAYER**" #F5E6FF {
    
    ' Data Extraction with Hybrid Models
    rectangle "**①Intake Agent**" as AG1 #9B59B6 {
        component "Document Classifier\n(Random Forest)" as ML_CLASS
        component "LayoutLM v3\n(NER - vLLM)" as LAYOUTLM
        component "GPT-4o Vision\n(Fallback)" as M1
        component "OCR Pipeline" as OCR
        ML_CLASS .down.> LAYOUTLM : 85%
        LAYOUTLM .down.> M1 : fallback 13%
        M1 .down.> OCR
    }
    
    ' Eligibility & Benefits with In-House Models
    rectangle "**②Eligibility Agent**" as AG2 #8E44AD {
        component "Llama 8B INT8\n(Primary)" as LLAMA8B_E
        component "GPT-3.5 Turbo\n(Fallback)" as M2
        component "DB Queries" as DB2
        LLAMA8B_E .down.> M2 : fallback 8%
        M2 .down.> DB2
    }
    
    rectangle "**③Benefits Agent**" as AG3 #8E44AD {
        component "Llama 8B INT8\n(Primary)" as LLAMA8B_B
        component "GPT-3.5 Turbo\n(Fallback)" as M3
        component "Cost Calculator" as CALC
        LLAMA8B_B .down.> M3 : fallback 8%
        M3 .down.> CALC
    }
    
    ' Clinical Review with In-House LLM + DL Classification
    rectangle "**④Clinical Agent**" as AG4 #9B59B6 {
        component "Urgency Classifier\n(ResNet-50)" as DL_URGENCY
        component "Llama 70B Medical\n(Primary - vLLM)" as LLAMA70B_C
        component "GPT-4o\n(Fallback Complex)" as M4
        component "RAG Pipeline\n(430ms)" as RAG
        component "Vector Search\n(Milvus)" as VEC
        component "BM25 Search\n(Elasticsearch)" as BM25
        component "Graph RAG\n(Neo4j)" as GRAPH
        component "Reranker" as RERANK
        
        DL_URGENCY .down.> LLAMA70B_C : triage
        LLAMA70B_C .down.> M4 : fallback 25%
        M4 .down.> RAG
        RAG .down.> VEC
        RAG .down.> BM25
        RAG .down.> GRAPH
        VEC .down.> RERANK
        BM25 .down.> RERANK
        GRAPH .down.> RERANK
    }
    
    ' Policy & Fraud with In-House Models
    rectangle "**⑤Policy Agent**" as AG5 #D2691E {
        component "Llama 70B Policy\n(Primary - vLLM)" as LLAMA70B_P
        component "Claude 3.5\n(Complex Cases)" as M5
        component "Policy Search" as POL
        LLAMA70B_P .down.> M5 : fallback 23%
        M5 .down.> POL
    }
    
    rectangle "**⑥Fraud Agent**" as AG6 #9B59B6 {
        component "XGBoost\n(Risk Scorer)" as ML_FRAUD
        component "GPT-4o\n(Pattern Analysis)" as M6
        component "Graph Analysis\n(Neo4j)" as FRAUD_G
        ML_FRAUD .down.> M6 : high-risk 23%
        M6 .down.> FRAUD_G
    }
    
    ' Decision Synthesis with In-House Model
    rectangle "**⑦Decision Agent**" as AG7 #9B59B6 {
        component "Llama 70B\n(Primary)" as LLAMA70B_D
        component "GPT-4o\n(Fallback)" as M7
        component "Confidence\nAggregator" as CONF
        component "HITL Router" as HITL
        LLAMA70B_D .down.> M7 : fallback 25%
        M7 .down.> CONF
        CONF .down.> HITL
    }
    
    ' Supporting Agents
    agent "⑧Appeals" as AG8
    agent "⑨Notification" as AG9
    agent "⑩Audit" as AG10
    agent "⑪Communication" as AG11
}

' ============================================================================
' MODEL SERVING INFRASTRUCTURE
' ============================================================================

package "**Model Serving Infrastructure**" #E8F5E9 {
    rectangle "**vLLM Server**" as VLLM #81C784 {
        component "Llama 70B Medical FT\n(4x A100 80GB)" as VLLM_70B
        component "Llama 8B Eligibility FT\n(1x A100 40GB INT8)" as VLLM_8B
        component "LayoutLM v3 Medical FT\n(1x A100 40GB)" as VLLM_LAYOUTLM
    }
    
    rectangle "**SageMaker Endpoints**" as SAGEMAKER #66BB6A {
        component "ResNet-50\nUrgency Classifier\n(ml.g4dn.xlarge)" as SM_RESNET
        component "Random Forest\nDoc Classifier\n(ml.m5.large)" as SM_RF
        component "XGBoost\nFraud Scorer\n(ml.c5.xlarge)" as SM_XGB
    }
    
    rectangle "**Proprietary APIs**" as PROPRIETARY #4CAF50 {
        component "Azure OpenAI\n(GPT-4o, GPT-3.5)" as OPENAI_API
        component "Anthropic API\n(Claude 3.5)" as CLAUDE_API
    }
}

' ============================================================================
' EXTERNAL SYSTEMS
' ============================================================================

' Orchestration Layer
cloud "**Orchestration Layer**\n(LangGraph)" as ORCH #E6F7FF

' MCP Tools
package "**MCP Tools (45+)**" #FFF5E6 {
    component "parse_x12_278" as T1
    component "get_member_policy" as T2
    component "rag_search_clinical" as T3
    component "check_provider_sanctions" as T4
    component "..." as T_MORE
}

' Databases
database "PostgreSQL 15\n(6 databases)" as PG #E74C3C
database "Redis 7.0\n(Cache)" as REDIS #FF7043
database "Milvus 2.3\n(10M vectors)" as MILVUS #81C784
database "Elasticsearch 8\n(Clinical docs)" as ES #FFD700
database "Neo4j 5.x\n(Knowledge graph)" as NEO4J #00CED1

' Governance Layer
cloud "**Governance Layer**\n(Safety & Compliance)" as GOV #FFF5E6

' ============================================================================
' CONNECTIONS
' ============================================================================

' Orchestration to Agents
ORCH -[#0066CC,thickness=3]down-> AG1 : <b>①Intake</b>\n1.8s
ORCH -[#0066CC,thickness=2]down-> AG2 : <b>②Eligibility</b>\n0.28s
ORCH -[#0066CC,thickness=2]down-> AG3 : <b>③Benefits</b>\n0.32s
