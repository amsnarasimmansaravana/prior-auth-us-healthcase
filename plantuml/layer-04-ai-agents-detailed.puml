AG4 -[#228B22,thickness=2]-> SM_RESNET : triage
AG4 -[#228B22,thickness=3]-> VLLM_70B : primary 75%
AG4 -[#666666,dashed]-> OPENAI_API : fallback 25%

AG5 -[#228B22,thickness=3]-> VLLM_70B : primary 77%
AG5 -[#666666,dashed]-> CLAUDE_API : fallback 23%

AG6 -[#228B22,thickness=2]-> SM_XGB : primary 77%
AG6 -[#666666,dashed]-> OPENAI_API : fallback 23%

AG7 -[#228B22,thickness=2]-> VLLM_70B : primary 75%
AG7 -[#666666,dashed]-> OPENAI_API : fallback 25%

' Agents to Databases
AG2 -[#9932CC]-> PG : query
AG3 -[#9932CC]-> PG
AG4 -[#228B22,thickness=2]-> MILVUS : <b>Vector</b>
AG4 -[#228B22,thickness=2]-> ES : <b>BM25</b>
AG4 -[#228B22,thickness=2]-> NEO4J : <b>Graph</b>
AG2 -[#666666,dashed]-> REDIS : cache
AG3 -[#666666,dashed]-> REDIS

' Agents to Governance
AG1 .up.> GOV : safety check
AG2 .up.> GOV
AG3 .up.> GOV
AG4 .up.> GOV
AG5 .up.> GOV
AG6 .up.> GOV
AG7 .up.> GOV

