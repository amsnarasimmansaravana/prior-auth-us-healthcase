@startuml Multi-Region Active-Active Deployment
!include <C4/C4_Deployment>

skinparam backgroundColor #FEFEFE
skinparam defaultFontName Arial

title Healthcare Insurance Multi-Agent AI Platform\nMulti-Region Active-Active Deployment Architecture\n(Azure - High Availability & Disaster Recovery)

Deployment_Node(azureglobal, "Azure Global Services", "Global") {
  Deployment_Node(frontdoor, "Azure Front Door", "Global CDN & WAF") {
    Container(fd, "Front Door", "CDN, WAF, SSL", "Global traffic distribution\nDDoS protection\nSSL termination")
  }
  
  Deployment_Node(trafficmgr, "Traffic Manager", "DNS-based Load Balancing") {
    Container(tm, "Traffic Manager", "DNS LB", "Performance routing\nHealth monitoring\nAuto-failover")
  }
  
  Deployment_Node(aad, "Azure Active Directory", "Global") {
    Container(identity, "AAD", "Identity", "Authentication\nAuthorization\nMFA")
  }
}

Deployment_Node(primary, "PRIMARY REGION: East US 2", "Production") {
  Deployment_Node(akseast, "AKS Cluster East", "Kubernetes 1.28") {
    Deployment_Node(nseast, "Namespace: healthcare-prod", "Isolated") {
      Container(agentseast, "Agent Services", "FastAPI, Python", "10 Clinical Agents\n8 Intake Agents\n5 Policy Agents\n6 Fraud Agents\n4 Decision Agents")
      
      Container(orcheast, "Orchestration", "LangGraph, Temporal", "Workflow engine\nSupervisor pattern\nState management")
      
      Container(apieast, "API Gateway", "Kong, Istio", "Rate limiting\nmTLS\nService mesh")
    }
  }
  
  Deployment_Node(dataeast, "Data Services East", "Azure PaaS") {
    ContainerDb(pgeast, "PostgreSQL", "Flexible Server", "HA: Zone-redundant\nvCores: 32\nStorage: 2TB\nBackup: Daily")
    
    ContainerDb(rediseast, "Redis Cache", "Premium P4", "Cluster mode\n26GB memory\nHA: Zone-redundant")
    
    ContainerDb(milvuseast, "Milvus", "AKS StatefulSet", "10M vectors\nHNSW index\nReplicas: 3")
    
    ContainerDb(neo4jeast, "Neo4j", "AKS StatefulSet", "500K nodes\n2M edges\nCausal cluster")
  }
  
  Deployment_Node(storageeast, "Storage East", "Azure Storage") {
    ContainerDb(blobeast, "Blob Storage", "Hot tier, ZRS", "Documents\nModels\nBackups")
  }
  
  Deployment_Node(obseast, "Observability East", "Monitoring") {
    Container(promeast, "Prometheus", "Metrics", "Agent metrics\nInfra metrics\n200+ metrics")
    
    Container(grafanaeast, "Grafana", "Dashboards", "Real-time dashboards\nAlerting")
  }
}

Deployment_Node(secondary, "SECONDARY REGION: West US 2", "Production") {
  Deployment_Node(akswest, "AKS Cluster West", "Kubernetes 1.28") {
    Deployment_Node(nswest, "Namespace: healthcare-prod", "Isolated") {
      Container(agentswest, "Agent Services", "FastAPI, Python", "10 Clinical Agents\n8 Intake Agents\n5 Policy Agents\n6 Fraud Agents\n4 Decision Agents")
      
      Container(orchwest, "Orchestration", "LangGraph, Temporal", "Workflow engine\nSupervisor pattern\nState management")
      
      Container(apiwest, "API Gateway", "Kong, Istio", "Rate limiting\nmTLS\nService mesh")
    }
  }
  
  Deployment_Node(datawest, "Data Services West", "Azure PaaS") {
    ContainerDb(pgwest, "PostgreSQL", "Read Replica", "Read-only replica\nAsync replication\nFailover capable")
    
    ContainerDb(rediswest, "Redis Cache", "Premium P4", "Cluster mode\n26GB memory\nHA: Zone-redundant")
    
    ContainerDb(milvuswest, "Milvus", "AKS StatefulSet", "Replica set\nSync from East\nRead-only")
    
    ContainerDb(neo4jwest, "Neo4j", "AKS StatefulSet", "Read replica\nCausal cluster")
  }
  
  Deployment_Node(storagewest, "Storage West", "Azure Storage") {
    ContainerDb(blobwest, "Blob Storage", "Hot tier, GRS", "Geo-replicated\nRead access")
  }
  
  Deployment_Node(obswest, "Observability West", "Monitoring") {
    Container(promwest, "Prometheus", "Metrics", "Agent metrics\nInfra metrics")
    
    Container(grafanawest, "Grafana", "Dashboards", "Real-time dashboards\nAlerting")
  }
}

Deployment_Node(shared, "SHARED SERVICES", "Cross-Region") {
  Deployment_Node(keyvault, "Azure Key Vault", "Secrets Management") {
    Container(secrets, "Key Vault", "HSM-backed", "API keys\nCertificates\nConnection strings")
  }
  
  Deployment_Node(analytics, "Analytics Services", "Central") {
    ContainerDb(synapse, "Synapse Analytics", "Data Warehouse", "Aggregated metrics\nBI reporting\nData lake")
    
    Container(loganalytics, "Log Analytics", "Central Logging", "All logs\nSIEM integration\n30-day retention")
  }
  
  Deployment_Node(backup_node, "Backup & DR", "Geo-Redundant") {
    ContainerDb(backup_db, "Azure Backup", "Vault", "Daily backups\n35-day retention\nCross-region")
  }
}

' Connections
fd --> tm : Route traffic
tm --> apieast : 60% traffic (performance)
tm --> apiwest : 40% traffic (geo-distribution)

apieast --> agentseast : Load balance
agentseast --> orcheast : Workflow orchestration
orcheast --> pgeast : Primary DB (write)
orcheast --> rediseast : Cache
orcheast --> milvuseast : Vector search
orcheast --> neo4jeast : Graph queries

apiwest --> agentswest : Load balance
agentswest --> orchwest : Workflow orchestration
orchwest --> pgwest : Read replica
orchwest --> rediswest : Cache
orchwest --> milvuswest : Vector search
orchwest --> neo4jwest : Graph queries

pgeast -[#red,dashed]-> pgwest : Async replication\n<5 sec lag
milvuseast -[#red,dashed]-> milvuswest : Data sync
blobeast -[#red,dashed]-> blobwest : Geo-replication\n(GRS)

agentseast --> identity : Auth/AuthZ
agentswest --> identity : Auth/AuthZ

agentseast --> secrets : Get secrets
agentswest --> secrets : Get secrets

promeast --> loganalytics : Push logs
promwest --> loganalytics : Push logs

pgeast --> backup : Daily backup
pgwest --> backup : Daily backup

note right of fd
  **Azure Front Door:**
  • Global anycast network
  • WAF: OWASP ruleset
  • DDoS protection: Layer 7
  • SSL offloading
  • Cache: Static assets
  • Latency: <50ms globally
end note

note right of tm
  **Traffic Manager Routing:**
  
  **Method:** Performance
  (route to fastest endpoint)
  
  **Endpoints:**
  • East US 2 (Priority 1)
  • West US 2 (Priority 2)
  
  **Health Probe:**
  • Interval: 10 seconds
  • Timeout: 5 seconds
  • Failures: 3 (mark unhealthy)
  
  **Traffic Split:**
  • Normal: 60% East, 40% West
  • East failure: 100% West
  • Auto-failover: <30 seconds
end note

note right of akseast
  **AKS East Configuration:**
  
  **Node Pools:**
  • System: 3 nodes (Standard_D4s_v3)
  • Agent: 10 nodes (Standard_D16s_v3)
  • Spot: 5 nodes (cost savings)
  
  **Features:**
  • Zone redundancy (3 AZs)
  • Auto-scaling: 10-30 nodes
  • Pod autoscaling: HPA enabled
  • Network: Azure CNI
  • Policy: Azure Policy + OPA
  
  **Service Mesh:**
  • Istio 1.20
  • mTLS: STRICT
  • Circuit breaker: Enabled
  
  **Total Capacity:**
  • vCPUs: 640
  • Memory: 2.5 TB
  • Peak throughput: 1500 req/s
end note

note right of pgeast
  **PostgreSQL HA Setup:**
  
  **Configuration:**
  • Version: 15
  • vCores: 32
  • Memory: 128 GB
  • Storage: 2 TB (P30)
  • IOPS: 20,000
  
  **High Availability:**
  • Zone-redundant HA
  • Standby replica (different AZ)
  • Auto-failover: <60 seconds
  • Read replicas: 1 in West US 2
  
  **Backup:**
  • Automated: Daily
  • Retention: 35 days
  • PITR: 5-minute granularity
  • Geo-backup: Enabled
  
  **Performance:**
  • Connection pooling: PgBouncer
  • Max connections: 500
  • Query timeout: 30s
end note

note right of rediseast
  **Redis Cache Configuration:**
  
  **Tier:** Premium P4
  • Memory: 26 GB
  • Bandwidth: 4 Gbps
  • Connections: 40,000
  
  **HA:**
  • Zone redundancy
  • Automatic failover
  • Persistence: AOF + RDB
  
  **Use Cases:**
  • Session state
  • Agent working memory
  • Response caching
  • Rate limiting
  
  **Performance:**
  • Latency: <1ms (P50)
  • Hit rate: 85%
  • Eviction: LRU
end note

note right of akswest
  **AKS West Configuration:**
  
  **Identical to East:**
  • Same node pools
  • Same configuration
  • Same service mesh
  
  **Active-Active Benefits:**
  • Geo-distribution
  • Lower latency (West Coast)
  • Load distribution
  • DR capability
  
  **Difference:**
  • Database: Read replicas only
  • Vector DB: Read replicas
  • Writes: Proxied to East
end note

note right of pgwest
  **Read Replica Strategy:**
  
  **Replication:**
  • Type: Async streaming
  • Lag: <5 seconds (P95)
  • Monitoring: Continuous
  
  **Use Cases:**
  • Read-heavy queries
  • Reporting
  • Analytics
  • Failover target
  
  **Failover Process:**
  1. Detect East failure
  2. Promote West to primary
  3. Update connection strings
  4. Switch DNS
  **Time:** ~5 minutes
end note

note right of backup
  **Disaster Recovery:**
  
  **RTO (Recovery Time Objective):**
  • Target: 4 hours
  • Actual: 2.5 hours (tested)
  
  **RPO (Recovery Point Objective):**
  • Target: 15 minutes
  • Actual: <5 minutes
  
  **DR Drill:**
  • Frequency: Quarterly
  • Last drill: April 2026
  • Success: ✓ All systems recovered
  
  **Backup Schedule:**
  • PostgreSQL: Daily + PITR
  • Milvus: Daily snapshots
  • Redis: AOF + RDB
  • Blob: Geo-replication
  
  **Retention:**
  • Daily: 35 days
  • Weekly: 12 weeks
  • Monthly: 12 months
  • Yearly: 7 years (compliance)
end note

note bottom
  **Deployment Statistics:**
  
  **Total Infrastructure:**
  • Regions: 2 (primary + secondary)
  • AKS clusters: 2
  • Total nodes: 30 (can scale to 60)
  • Total vCPUs: 1,280
  • Total memory: 5 TB
  
  **High Availability:**
  • Uptime SLA: 99.9%
  • Actual uptime: 99.92%
  • Downtime last 12 months: 7 hours
  • Incidents: 3 (all resolved <1 hour)
  
  **Performance:**
  • Global latency P95: 180ms
  • US East latency P95: 95ms
  • US West latency P95: 110ms
  • Failover time: 25 seconds (actual)
  
  **Cost (Monthly):**
  • AKS: $30K
  • Databases: $16K
  • Storage: $4K
  • Networking: $6K
  • Monitoring: $2K
  • **Total:** $58K/month
  
  **Cost Optimization:**
  • Spot instances: 30% savings
  • Reserved instances: 40% savings
  • Right-sizing: 25% reduction
end note

@enduml
