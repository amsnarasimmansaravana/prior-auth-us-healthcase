@startuml layer-01-presentation
!theme aws-orange
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam nodesep 100
skinparam ranksep 80
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam defaultFontSize 11
skinparam componentFontSize 10

title <size:18><b>Layer 1: Presentation Layer - Channel Services</b></size>\n<size:14>Multi-Channel Intake | 50,000 PA Requests/Day | 6 Services</size>\n\n

' Define colors
!define WEB_COLOR #4FC3F7
!define MOBILE_COLOR #29B6F6
!define PROVIDER_COLOR #0288D1
!define EDI_COLOR #0277BD
!define FAX_COLOR #01579B
!define IVR_COLOR #006064

'===================================================================
' EXTERNAL ACTORS
'===================================================================
actor "Member\n(Patient)" as Member
actor "Provider\nOffice Staff" as Provider
actor "Payer\nAdministrator" as Payer
actor "Phone\nCaller" as Caller

'===================================================================
' LAYER 1: CHANNEL SERVICES
'===================================================================
rectangle "**PRESENTATION LAYER**" as PresentationLayer #F0F8FF {

    '=== WEB PORTAL SERVICE ===
    component "**Web Portal Service**\n(web-portal-svc)" as WebPortal WEB_COLOR {
        [React 18.2 + Next.js 14\nTypeScript 5.1] as WebFrontend
        [Node.js 20 (BFF)\nExpress.js 4.18] as WebBackend
        [Material-UI 5.14\nReact Hook Form] as WebUI
        [Socket.io (WebSocket)] as WebSocket
        
        WebFrontend -down-> WebBackend : REST API
        WebBackend -down-> WebSocket : Real-time
    }
    
    '=== MOBILE API SERVICE ===
    component "**Mobile API Service**\n(mobile-api-svc)" as MobileAPI MOBILE_COLOR {
        [FastAPI 0.104\nPython 3.11] as MobileFastAPI
        [Pydantic 2.4\nValidation] as MobileValidation
        [JWT Auth\nOAuth2] as MobileAuth
        [FCM + APNS\nPush Notifications] as MobilePush
        
        MobileFastAPI -down-> MobileValidation : Data validation
        MobileFastAPI -down-> MobileAuth : Authentication
        MobileFastAPI -down-> MobilePush : Notifications
    }
    
    '=== PROVIDER PORTAL SERVICE ===
    component "**Provider Portal Service**\n(provider-portal-svc)" as ProviderPortal PROVIDER_COLOR {
        [Angular 16\nTypeScript 5.1] as ProviderFrontend
        [NestJS 10.2\nNode.js 20] as ProviderBackend
        [PrimeNG 16\nUI Components] as ProviderUI
        [NgRx 16\nState Management] as ProviderState
        
        ProviderFrontend -down-> ProviderBackend : REST API
        ProviderFrontend -down-> ProviderState : State mgmt
    }
    
    '=== EDI GATEWAY SERVICE ===
    component "**EDI Gateway Service**\n(edi-gateway-svc)" as EDIGateway EDI_COLOR {
        [Go 1.21\nX12 Parser] as EDIParser
        [HIPAA 5010\nValidator] as EDIValidator
        [HL7 FHIR R4\nConverter] as EDIConverter
        [AS2/SFTP/HTTPS\nTransport] as EDITransport
        
        EDIParser -down-> EDIValidator : Validate
        EDIValidator -down-> EDIConverter : Convert to FHIR
        EDIConverter -down-> EDITransport : Send
    }
    
    '=== FAX OCR SERVICE ===
    component "**Fax OCR Service**\n(fax-ocr-svc)" as FaxOCR FAX_COLOR {
        [Python 3.11\nOpenCV 4.8] as FaxProcessor
        [Azure Form Recognizer\nCustom Models] as FaxOCREngine
        [Twilio Fax API\nRingCentral] as FaxReceiver
        [Image Processing\nDeskew + Denoise] as FaxPreprocess
        
        FaxReceiver -down-> FaxPreprocess : Pre-process
        FaxPreprocess -down-> FaxOCREngine : OCR
        FaxOCREngine -down-> FaxProcessor : Extract data
    }
    
    '=== VOICE IVR SERVICE ===
    component "**Voice IVR Service**\n(voice-ivr-svc)" as VoiceIVR IVR_COLOR {
        [Node.js 20\nTypeScript] as IVRBackend
        [Azure Speech SDK\nSTT + TTS] as IVRSpeech
        [Twilio Programmable Voice] as IVRTwilio
        [Azure LUIS\nIntent Recognition] as IVRNLU
        
        IVRTwilio -down-> IVRSpeech : Speech processing
        IVRSpeech -down-> IVRNLU : Intent recognition
        IVRNLU -down-> IVRBackend : Route call
    }
}

'===================================================================
' DOWNSTREAM LAYERS (SIMPLIFIED)
'===================================================================
rectangle "**API GATEWAY LAYER**" as APIGateway #FFF8DC {
    hexagon "Auth Gateway\n(OAuth2/JWT)" as AuthGW #F39C12
    hexagon "Rate Limit\nGateway" as RateLimitGW #F39C12
  hexagon "Kong AI Gateway\n(Security + Governance)" as KongAIGW #F39C12
  hexagon "LiteLLM Gateway\n(Routing + Fallback)" as LiteLLMGW #F39C12
}

rectangle "**ORCHESTRATION LAYER**" as Orchestration #E6F7FF {
    component "Workflow Engine\n(LangGraph)" as WorkflowEngine #4A90E2
}

'===================================================================
' DATA STORES
'===================================================================
database "PostgreSQL 15\n6 DBs | 6 TB\npa_cases, members,\nproviders" as PostgreSQL #E74C3C

database "Redis 7.0\n26 GB Cluster\nSessions, Cache,\nRate Limits" as Redis #FF7043

database "Azure Blob Storage\n10 TB\nDocuments, PDFs,\nFax Images" as BlobStorage #B71C1C

database "Kafka\nEvent Bus\n6 Brokers\npa.case.created" as Kafka #607D8B

'===================================================================
' EXTERNAL SYSTEMS
'===================================================================
cloud "External Systems" as External {
    component "Twilio\nFax + Voice" as Twilio #90A4AE
    component "Azure Speech\nServices" as AzureSpeech #78909C
    component "Azure Form\nRecognizer" as AzureFormRec #607D8B
    component "Trading Partners\n(X12 EDI)" as TradingPartners #546E7A
}

'===================================================================
' CONNECTIONS: USERS → SERVICES
'===================================================================
Member -down-> WebPortal : <b>Web Browser</b>\nHTTPS
Member -down-> MobileAPI : <b>Mobile App</b>\niOS/Android

Provider -down-> ProviderPortal : <b>Provider Portal</b>\nHTTPS
Provider -down-> EDIGateway : <b>X12 EDI</b>\n278 Request
Provider -down-> FaxOCR : <b>Fax</b>\nTIFF/PDF

Payer -down-> WebPortal : <b>Admin Portal</b>\nHTTPS

Caller -down-> VoiceIVR : <b>Phone Call</b>\nPSTN

'===================================================================
' CONNECTIONS: SERVICES → API GATEWAY
'===================================================================
WebPortal -[#0066CC,thickness=2]down-> AuthGW : <b>POST /api/v1/pa/submit</b>\nREST API
MobileAPI -[#0066CC,thickness=2]down-> AuthGW : <b>POST /api/mobile/v1/pa/submit</b>\nREST API
ProviderPortal -[#0066CC,thickness=2]down-> AuthGW : <b>POST /api/provider/v1/pa/submit</b>\nREST API
EDIGateway -[#0066CC,thickness=2]down-> RateLimitGW : <b>X12 → JSON</b>\nConverted
FaxOCR -[#0066CC,thickness=2]down-> KongAIGW : <b>OCR Results</b>\nJSON
VoiceIVR -[#0066CC,thickness=2]down-> AuthGW : <b>API Calls</b>\nREST

'===================================================================
' CONNECTIONS: API GATEWAY → ORCHESTRATION
'===================================================================
AuthGW -[#0066CC,thickness=3]down-> WorkflowEngine : <b>Authenticated Requests</b>
RateLimitGW -[#0066CC,thickness=3]down-> WorkflowEngine : <b>Rate-Limited Requests</b>
KongAIGW -[#0066CC,thickness=3]down-> LiteLLMGW : <b>LLM Policy + Routing</b>
LiteLLMGW -down-> WorkflowEngine : <b>Routed Requests</b>

'===================================================================
' CONNECTIONS: SERVICES → DATABASES
'===================================================================
WebBackend -[#666666,dashed]down-> PostgreSQL : <b>Create PA Case</b>\nINSERT
MobileFastAPI -[#666666,dashed]down-> PostgreSQL : <b>Query Data</b>\nSELECT
ProviderBackend -[#666666,dashed]down-> PostgreSQL : <b>Bulk Operations</b>\nBATCH INSERT

WebBackend -[#666666,dashed]down-> Redis : <b>Session Store</b>\nSET/GET
MobileFastAPI -[#666666,dashed]down-> Redis : <b>Cache</b>\nCache-aside
ProviderBackend -[#666666,dashed]down-> Redis : <b>Rate Limit</b>\nINCR

WebBackend -[#666666,dashed]down-> BlobStorage : <b>Upload Documents</b>\nPUT
FaxProcessor -[#666666,dashed]down-> BlobStorage : <b>Store Fax Images</b>\nPUT

WebBackend -[#666666,dashed]down-> Kafka : <b>Publish Event</b>\npa.case.created
MobileFastAPI -[#666666,dashed]down-> Kafka : <b>Publish Event</b>\npa.case.created
ProviderBackend -[#666666,dashed]down-> Kafka : <b>Publish Event</b>\npa.case.created

'===================================================================
' CONNECTIONS: SERVICES → EXTERNAL SYSTEMS
'===================================================================
FaxReceiver -[#00AA55,dashed]up-> Twilio : <b>Webhook</b>\nInbound Fax
IVRTwilio -[#00AA55,dashed]up-> Twilio : <b>Voice API</b>\nInbound Call

IVRSpeech -[#00AA55,dashed]up-> AzureSpeech : <b>STT + TTS</b>\nHTTPS

FaxOCREngine -[#00AA55,dashed]up-> AzureFormRec : <b>Form Recognizer API</b>\nHTTPS

EDITransport -[#00AA55,dashed]up-> TradingPartners : <b>AS2/SFTP</b>\nX12 278 Response

'===================================================================
' ANNOTATIONS
'===================================================================
note top of PresentationLayer
  <b>LAYER 1: PRESENTATION LAYER</b>
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  <b>Services:</b> 6 channel services
  <b>Daily Volume:</b> 50,000 PA requests
  <b>Channels:</b> Web, Mobile, Provider, EDI, Fax, IVR
  <b>Deployment:</b> Azure Kubernetes Service (AKS)
  <b>Load Balancer:</b> Azure Application Gateway
  <b>Uptime SLA:</b> 99.95%
