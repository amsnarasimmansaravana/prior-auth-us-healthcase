@startuml RAG Architecture - Hybrid Retrieval
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Arial

title Healthcare Insurance Multi-Agent AI Platform\nRAG Architecture - Hybrid Retrieval System\n(Vector + Keyword + Knowledge Graph)

actor "Clinical Agent" as Agent

package "Query Processing Layer" {
  rectangle "Query Analysis" as QueryAnalysis #E3F2FD {
    ' Query understanding
    ' Intent detection
    ' Entity extraction
    ' Query expansion
  }
  
  rectangle "Query Rewriting" as Rewrite #FFF3E0 {
    ' Synonym expansion
    ' Medical term normalization
    ' Acronym expansion
  }
}

package "Retrieval Layer" {
  rectangle "**Retrieval Strategy Router**" as Router #E8F5E9 {
    ' Query type classification
    ' Strategy selection
    ' Metadata filters
  }
  
  package "Parallel Retrieval" {
    rectangle "**Vector Search**\n(Semantic)" as Vector #E3F2FD {
      rectangle "Embedding Generation" as Embed {
        ' Model: BGE-large-en-v1.5
        ' Dimension: 1024
        ' Batch size: 32
      }
      
      rectangle "Milvus Vector DB" as Milvus {
        database "Clinical Guidelines\n(5M vectors)" as ClinicalVec
        database "Policy Documents\n(2M vectors)" as PolicyVec
        database "Case History\n(10M vectors)" as CaseVec
      }
      
      rectangle "Cosine Similarity Search" as Cosine {
        ' Top-K: 100
        ' Threshold: 0.7
        ' HNSW index
      }
    }
    
    rectangle "**Keyword Search**\n(Lexical)" as Keyword #FFF3E0 {
      rectangle "BM25 Indexer" as BM25 {
        ' Elasticsearch
        ' TF-IDF scoring
        ' Field boosting
      }
      
      rectangle "Full-Text Search" as FTS {
        ' Top-K: 100
        ' Fuzzy matching
        ' Phrase matching
      }
    }
    
    rectangle "**Knowledge Graph**\n(Structured)" as KG #E8F5E9 {
      rectangle "Neo4j Graph DB" as Neo4j {
        database "Disease Ontology" as Disease
        database "Drug Interactions" as Drug
        database "Provider Networks" as Provider
      }
      
      rectangle "Graph Traversal" as Traversal {
        ' Cypher queries
        ' Multi-hop relationships
        ' Pathfinding
      }
    }
  }
}

package "Fusion & Ranking Layer" {
  rectangle "**Result Fusion**" as Fusion #FCE4EC {
    ' Reciprocal Rank Fusion (RRF)
    ' Score normalization
    ' Duplicate removal
  }
  
  rectangle "**Metadata Filtering**" as Filter #F3E5F5 {
    ' Document type filter
    ' Date range filter
    ' Organization filter
    ' Relevance threshold
  }
  
  rectangle "**Reranking**" as Rerank #E0F2F1 {
    rectangle "Cross-Encoder" as CrossEncoder {
      ' Model: ms-marco-MiniLM
      ' Query-document pairs
      ' Precise relevance scoring
    }
    
    rectangle "Diversity Filter" as Diversity {
      ' MMR (Maximal Marginal Relevance)
      ' Avoid redundancy
      ' Ensure coverage
    }
  }
}

package "Context Preparation Layer" {
  rectangle "**Context Compression**" as Compression #FFF9C4 {
    rectangle "LLMLingua" as Lingua {
      ' Token reduction
      ' Preserve key information
      ' Compression ratio: 50%
    }
    
    rectangle "Chunking Optimizer" as ChunkOpt {
      ' Semantic chunking
      ' Overlap: 20%
      ' Max chunk: 512 tokens
    }
  }
  
  rectangle "**Citation Tracking**" as Citation #E1F5FE {
    ' Source document ID
    ' Page number
    ' Confidence score
    ' Retrieval timestamp
  }
}

package "LLM Integration Layer" {
  rectangle "**Prompt Construction**" as Prompt #FFEBEE {
    ' System prompt
    ' Retrieved context
    ' User query
    ' Few-shot examples
  }
  
  rectangle "**GPT-4o LLM**" as LLM #E3F2FD {
    ' Model: gpt-4o-2024-05-13
    ' Temperature: 0.1
    ' Max tokens: 4096
    ' Top-p: 0.95
  }
  
  rectangle "**Response Validation**" as Validation #FFF3E0 {
    ' Groundedness check
    ' Citation validation
    ' Hallucination detection
    ' Confidence scoring
  }
}

package "Observability & Optimization" {
  rectangle "**RAG Evaluation**" as Eval #E8F5E9 {
    ' Context Precision
    ' Context Recall
    ' Answer Relevancy
    ' Faithfulness
  }
  
  rectangle "**Performance Metrics**" as Metrics #FCE4EC {
    ' Retrieval latency (P95: 120ms)
    ' Reranking latency (P95: 200ms)
    ' Total RAG latency (P95: 3.2s)
    ' Cache hit rate: 35%
  }
}

' Flow
Agent --> QueryAnalysis : "Does this patient meet\nMCG criteria for knee MRI?"

QueryAnalysis --> Rewrite : Expand query

Rewrite --> Router : Optimized query

Router --> Vector : Parallel execution
Router --> Keyword : Parallel execution
Router --> KG : Parallel execution

Vector --> Embed : Generate embeddings
Embed --> Milvus : Search vectors
Milvus --> Cosine : Top-K=100

Keyword --> BM25 : Index search
BM25 --> FTS : Top-K=100

KG --> Neo4j : Graph query
Neo4j --> Traversal : Multi-hop search

Cosine --> Fusion : Vector results (100)
FTS --> Fusion : Keyword results (100)
Traversal --> Fusion : Graph results (50)

Fusion --> Filter : Merged results (250)

Filter --> Rerank : Filtered results (150)

Rerank --> CrossEncoder : Precise scoring
CrossEncoder --> Diversity : Top-K=50

Diversity --> Compression : Top-K=10

Compression --> Lingua : Compress
Lingua --> ChunkOpt : Optimize chunks

ChunkOpt --> Citation : Track sources

Citation --> Prompt : Context + Citations

Prompt --> LLM : Full prompt

LLM --> Validation : Generated response

Validation --> Agent : ✓ Validated answer\nwith citations

Validation --> Eval : Continuous evaluation

Eval --> Metrics : Performance tracking

